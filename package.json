{
  "name": "pgsearch",
  "version": "1.0.0",
  "description": "Lambda API with PostgreSQL database using Philadelphia constructs",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --filter './apps/*' --filter './packages/embeddings' --filter './packages/client' --filter './packages/ingest' test",
    "synth": "cd cdk && cdk synth",
    "deploy": "cd cdk && cdk deploy",
    "diff": "cd cdk && cdk diff"
  },
  "workspaces": [
    "cdk",
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "aws-cdk-lib": "2.236.0",
    "constructs": "10.4.4"
  }
}

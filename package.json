{
  "name": "pgsearch",
  "version": "1.0.0",
  "description": "Lambda API with PostgreSQL database using Philadelphia constructs",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --filter './apps/*' --filter './packages/embeddings' --filter './packages/client' --filter './packages/parse' test",
    "synth": "cd cdk && cdk synth",
    "deploy": "cd cdk && cdk deploy",
    "diff": "cd cdk && cdk diff",
    "dev:db": "docker compose -f docker-compose.test.yml up -d postgres",
    "dev:api": "DB_HOST=localhost DB_PORT=5433 DB_NAME=pgsearch_dev DB_USER=pgsearch DB_PASSWORD=testpassword tsx watch apps/api/local.ts",
    "dev:bootstrap": "tsx apps/api/scripts/bootstrap-dev-index.ts",
    "dev:crawl": "tsx apps/crawler/src/cli.ts --endpoint http://localhost:3000 --index phila-services-programs --sitemap https://www.phila.gov/sitemap.xml"
  },
  "workspaces": [
    "cdk",
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1025.0",
    "@types/node": "^20.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "aws-cdk-lib": "2.236.0",
    "constructs": "10.4.4"
  }
}

{
  "name": "pgsearch",
  "version": "1.0.0",
  "description": "Lambda API with PostgreSQL database using Philadelphia constructs",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --filter './apps/*' --filter './packages/embeddings' --filter './packages/client' --filter './packages/parse' test",
    "synth": "cd cdk && cdk synth",
    "deploy": "cd cdk && cdk deploy",
    "diff": "cd cdk && cdk diff",
    "dev:db": "docker compose -f docker-compose.test.yml up -d postgres",
    "dev:api": "DB_HOST=localhost DB_PORT=5433 DB_NAME=pgsearch_dev DB_USER=pgsearch DB_PASSWORD=testpassword tsx watch apps/api/local.ts",
    "dev:bootstrap": "tsx apps/api/scripts/bootstrap-dev-index.ts",
    "ingest:311-kb": "tsx --env-file=.env.local apps/api/scripts/ingest-311-kb.ts",
    "dev:crawl": "tsx apps/crawler/src/cli.ts --endpoint http://localhost:3000 --index phila-services-programs --seed https://www.phila.gov/services/ --seed https://www.phila.gov/programs/"
  },
  "workspaces": [
    "cdk",
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1084.0",
    "@types/node": "^20.10.0",
    "tsx": "^4.23.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "aws-cdk-lib": "2.236.0",
    "constructs": "10.4.4"
  },
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "postcss@<8.5.10": ">=8.5.10",
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "fast-xml-builder@<=1.1.6": ">=1.1.7",
      "vite": "^7.3.5"
    }
  }
}

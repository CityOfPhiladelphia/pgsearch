{
  "name": "api",
  "version": "1.0.0",
  "description": "Lambda function handler with PostgreSQL database access",
  "private": true,
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js",
    "watch": "esbuild index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@phila/db-postgres": "^0.0.8",
    "@phila/search-embeddings": "workspace:*",
    "bcryptjs": "^2.4.3",
    "hono": "^4.0.0",
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.24.0",
    "pg": "^8.20.0",
    "typescript": "^5.3.0",
    "vitest": "^3.1.0"
  }
}

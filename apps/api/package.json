{
  "name": "api",
  "version": "1.0.0",
  "description": "Lambda function handler with PostgreSQL database access",
  "private": true,
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@aws-sdk/*",
    "watch": "esbuild index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@aws-sdk/* --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@phila/bedrock-client": "workspace:*",
    "@phila/db-postgres": "^0.0.8",
    "@phila/llm": "workspace:*",
    "@phila/search-embeddings": "workspace:*",
    "bcryptjs": "^2.4.3",
    "hono": "^4.12.29",
    "pg": "^8.20.0",
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.10",
    "@phila/search-parse": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  }
}

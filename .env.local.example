# Copy this file to .env.local (gitignored) and fill in the secret values.
# Used by the 311 KB ingestion script: `pnpm run ingest:311-kb`.

# 311 knowledge-articles REST API
KB_API_BASE=https://yw32n3h725.execute-api.us-east-1.amazonaws.com/test
KB_API_KEY=

# pgsearch dev environment (target for the knowledge-311 index)
PGSEARCH_API_BASE=https://3qkikancml.execute-api.us-east-1.amazonaws.com/dev
PGSEARCH_ADMIN_KEY=

# Only required on re-runs, after the first-run banner prints it.
# Leave blank on first run.
KNOWLEDGE_311_INDEX_KEY=
